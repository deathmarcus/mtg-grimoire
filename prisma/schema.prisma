// Mtgcollection — Prisma schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5) — adapter tables
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // Credentials provider — null when the user signed up via OAuth
  passwordHash  String?
  // User preferences
  displayCurrency Currency @default(USD)
  collectionView  ViewMode @default(GRID)
  locale          String   @default("es")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  collections     Collection[]
  collectionItems CollectionItem[]
  wishlistItems   WishlistItem[]
  activityLogs    ActivityLog[]
  importLogs      ImportLog[]
  decks           Deck[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Scryfall catalog (global, shared across users)
// ---------------------------------------------------------------------------

model Card {
  // Scryfall UUID — stable primary key
  id              String  @id
  oracleId        String
  name            String
  setCode         String
  setName         String
  collectorNumber String
  rarity          String
  lang            String  @default("en")
  // Mana / types
  manaCost        String?
  cmc             Float?
  typeLine        String?
  oracleText      String? @db.Text
  colors          String[] @default([])
  colorIdentity   String[] @default([])
  // Image URIs from Scryfall CDN — we don't cache images locally
  imageSmall      String?
  imageNormal     String?
  imageLarge      String?
  // Flags
  foilAvailable   Boolean @default(false)
  nonfoilAvailable Boolean @default(true)
  etchedAvailable Boolean @default(false)
  // Latest prices (convenience — full history lives in CardPrice)
  latestUsd       Decimal? @db.Decimal(12, 2)
  latestUsdFoil   Decimal? @db.Decimal(12, 2)
  latestUsdEtched Decimal? @db.Decimal(12, 2)
  // Format legalities as JSON: { standard: "legal" | "not_legal" | "banned" | "restricted", ... }
  legalities      Json?
  // Sync bookkeeping
  scryfallUpdatedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  prices          CardPrice[]
  collectionItems CollectionItem[]
  wishlistItems   WishlistItem[]
  deckCards       DeckCard[]
  decksAsCover    Deck[]     @relation("DeckCoverCard")

  @@index([name])
  @@index([setCode, collectorNumber])
  @@index([oracleId])
}

// Weekly price snapshot — populated only for cards that at least one user owns.
model CardPrice {
  id             String   @id @default(cuid())
  cardId         String
  snapshotDate   DateTime @db.Date
  priceUsd       Decimal? @db.Decimal(12, 2)
  priceUsdFoil   Decimal? @db.Decimal(12, 2)
  priceUsdEtched Decimal? @db.Decimal(12, 2)

  card           Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, snapshotDate])
  @@index([snapshotDate])
}

// USD -> MXN weekly snapshot. Display-time MXN uses the same-date rate.
model FxRate {
  snapshotDate DateTime @id @db.Date
  usdToMxn     Decimal  @db.Decimal(12, 6)
  source       String
  createdAt    DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Per-user inventory
// ---------------------------------------------------------------------------

model Collection {
  id                 String   @id @default(cuid())
  userId             String
  name               String
  sortOrder          Int      @default(0)
  isDefault          Boolean  @default(false)
  excludeFromTotals  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@unique([userId, name])
  @@index([userId])
}

model CollectionItem {
  id            String    @id @default(cuid())
  userId        String
  collectionId  String
  cardId        String
  quantity      Int       @default(1)
  foil          FoilKind  @default(NORMAL)
  language      String    @default("en")
  condition     Condition @default(NM)
  acquiredAt    DateTime?
  acquiredPrice Decimal?  @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Restrict)
  card       Card       @relation(fields: [cardId], references: [id], onDelete: Restrict)

  @@unique([userId, collectionId, cardId, foil, language, condition])
  @@index([userId])
  @@index([collectionId])
  @@index([cardId])
}

// ---------------------------------------------------------------------------
// Wishlist
// ---------------------------------------------------------------------------

model WishlistItem {
  id             String    @id @default(cuid())
  userId         String
  cardId         String
  quantityWanted Int       @default(1)
  maxPriceUsd    Decimal?  @db.Decimal(12, 2)
  priority       Priority  @default(MEDIUM)
  tag            String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Restrict)

  @@unique([userId, cardId])
  @@index([userId])
  @@index([cardId])
  @@index([userId, tag])
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum FoilKind {
  NORMAL
  FOIL
  ETCHED
}

enum Condition {
  NM
  LP
  MP
  HP
  DMG
}

enum Currency {
  USD
  MXN
}

enum ViewMode {
  GRID
  TABLE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Board {
  MAIN
  SIDE
}

// ---------------------------------------------------------------------------
// Decks
// ---------------------------------------------------------------------------

model Deck {
  id          String   @id @default(cuid())
  userId      String
  name        String
  format      String   @default("") // e.g. "Modern", "Commander", "Legacy"
  description String?  @db.Text
  coverCardId String?  // nullable FK to Card; if null, use first mainboard card

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  coverCard Card?      @relation("DeckCoverCard", fields: [coverCardId], references: [id], onDelete: SetNull)
  cards     DeckCard[]

  @@index([userId])
}

model DeckCard {
  id          String   @id @default(cuid())
  deckId      String
  cardId      String
  quantity    Int      @default(1)
  isCommander Boolean  @default(false)
  board       Board    @default(MAIN)

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Restrict)

  @@unique([deckId, cardId, board])
  @@index([deckId])
  @@index([cardId])
}

// ---------------------------------------------------------------------------
// Activity log — append-only feed for the dashboard
// ---------------------------------------------------------------------------

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  payload   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// Import log — one row per successful applyImport call
// ---------------------------------------------------------------------------

model ImportLog {
  id          String   @id @default(cuid())
  userId      String
  filename    String
  cardCount   Int
  newCount    Int      @default(0)
  mergedCount Int      @default(0)
  format      String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
